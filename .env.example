# Copy to .env and fill in. .env is gitignored.

# Anthropic API key (https://console.anthropic.com/) — used by the Claude reasoning model.
ANTHROPIC_API_KEY=

# Local Neo4j (started via docker compose). NEO4J_PASSWORD must match docker-compose.yml.
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change-me
